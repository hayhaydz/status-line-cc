        "widgets": {
          "git": { "enabled": false },
          "context": { "enabled": false },
          "block": { "enabled": false },
          "tools": { "enabled": false }
        },
        "concurrencyLimits": {
          "glm-4.5": 10,
          "glm-4.7": 3,
          "glm-5": 3,
          "glm-4.5-air": 5
        }
      }
    },

    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.5" } } },

    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.7" } } },
    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-4.7" } } },

    { "type": "hook", "action": "pre-tool", "input": { "session_id": "high-load-10of10", "tool_name": "Task", "tool_input": { "model": "glm-5" } } },

    { "type": "hook", "action": "agent-start", "input": { "session_id": "high-load-10of10", "agent_id": "m45-1" } },
    { "type": "hook", "action": "agent-start", "input": { "session_id": "high-load-10of10", "agent_id": "m45-2" } },
