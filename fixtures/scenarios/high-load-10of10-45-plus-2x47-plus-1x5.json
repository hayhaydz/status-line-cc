    {
      "type": "render",
      "label": "render high load 10/10",
      "input": {
        "session_id": "high-load-10of10",
        "model": "glm-4.5-air"
      },
      "expect": {
        "contains": [
          "+4.5_1x:10/10",
          "+4.7_1x:2/3"
        ],
        "regex": [
          "\\+5_[23]x:1/3",
          "GLM-4.5-air 1x"
